{
  "name": "minibudget-api",
  "version": "1.0.0",
  "description": "Backend API for Minibudget App",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "set \"NODE_ENV=test\" && npx mocha \"tests/**/*.test.js\" --timeout 10000 --exit",
    "evidence": "node ./scripts/capture-contract-evidence.mjs",
    "verify": "npm test && npm run evidence",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:create": "node scripts/create-migration.cjs"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.1",
    "jwt-decode": "^3.1.2",
    "pg": "^8.11.2",
    "sequelize": "^6.32.1",
    "sequelize-auto-migrations-v2": "^1.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "babel-register": "^6.26.0",
    "chai": "^4.5.0",
    "chai-http": "^5.1.2",
    "glob": "^13.0.0",
    "mocha": "^10.8.2",
    "sequelize-cli": "^6.6.1",
    "supertest": "^7.1.4",
    "swagger-autogen": "^2.23.5"
  },
  "type": "module"
}
